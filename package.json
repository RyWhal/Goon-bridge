{
  "name": "congress-vibe-check",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:ui & npm run dev:api & wait",
    "dev:ui": "vite",
    "dev:api": "cd api && npm run dev",
    "build": "tsc && vite build",
    "build:api": "cd api && npm run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && npm run build:api",
    "deploy:api": "cd api && npm run deploy"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
